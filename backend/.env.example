# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# The URL to your PostgreSQL database
DATABASE_URL="postgresql://user:password@localhost:5432/mydb?schema=public"

# Environment
NODE_ENV="development"
PORT="3000"
FRONTEND_URL="*"

# Sentry & Alerting
SENTRY_DSN="https://xxx@xxx.ingest.sentry.io/xxx"
ALERT_WEBHOOK="https://discord.com/api/webhooks/xxx"

# JWT Auth
JWT_SECRET="supersecret_jwt_key_here"
JWT_REFRESH_SECRET="supersecret_refresh_key_here"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Storage Settings (local, s3, r2)
STORAGE_PROVIDER="local"

# AWS S3 / Cloudflare R2 Credentials (for future production activation)
AWS_ACCESS_KEY_ID="your_access_key_id"
AWS_SECRET_ACCESS_KEY="your_secret_access_key"
AWS_REGION="us-east-1"
AWS_BUCKET_NAME="your_bucket_name"
AWS_S3_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
